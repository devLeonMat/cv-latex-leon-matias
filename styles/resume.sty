%% ============================================================
%%  resume.sty  —  Professional CV Style
%%  Candidate : Roslin Leon Matias
%%  Engine    : XeLaTeX  (required for fontspec)
%%  Compatible: Overleaf · VS Code + LaTeX Workshop · MacTeX
%%
%%  INSTALL FONTS (if compiling locally):
%%    sudo tlmgr install sourcesanspro
%% ============================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{resume}[2026/07/14 v2.0 Roslin Leon Matias Resume Style]

%% ── Engine guard ────────────────────────────────────────────
\RequirePackage{ifxetex}
\ifxetex\else
  \PackageError{resume}%
    {This style requires XeLaTeX.\MessageBreak Compile with: xelatex resume.tex}%
    {Use xelatex instead of pdflatex or lualatex.}%
\fi

%% ── Page geometry  (A4, tight but comfortable margins) ──────
\RequirePackage[
  a4paper,
  top    = 1.6cm,
  bottom = 1.5cm,
  left   = 1.75cm,
  right  = 1.75cm
]{geometry}

%% ── Font packages ───────────────────────────────────────────
%%  fontspec loads OpenType/TrueType fonts via XeLaTeX.
%%  Source Sans 3 (formerly Source Sans Pro) is available in
%%  TeX Live via:  tlmgr install sourcesanspro
%%  It is also available by default on Overleaf.
\RequirePackage{fontspec}

\setmainfont{Source Sans 3}[
  BoldFont       = {Source Sans 3 Bold},
  ItalicFont     = {Source Sans 3 Italic},
  BoldItalicFont = {Source Sans 3 Bold Italic},
  Scale          = 1.0,
]
\setsansfont{Source Sans 3}

%% ── Color palette ───────────────────────────────────────────
%%  Navy-blue professional scheme — neutral for ATS and print.
\RequirePackage{xcolor}

\definecolor{cvName}     {HTML}{0D1B2A}   %% Deep navy   — candidate name
\definecolor{cvTitle}    {HTML}{1A3A5C}   %% Dark navy   — section headings, company names
\definecolor{cvAccent}   {HTML}{1D5B9E}   %% Medium blue — section rules, links
\definecolor{cvText}     {HTML}{2D3748}   %% Charcoal    — body text
\definecolor{cvMuted}    {HTML}{64748B}   %% Slate gray  — dates, secondary labels
\definecolor{cvRule}     {HTML}{93C5FD}   %% Sky blue    — horizontal rules under sections

%% ── Hyperref (links + PDF metadata) ─────────────────────────
\RequirePackage{hyperref}
\hypersetup{
  colorlinks  = true,
  urlcolor    = cvAccent,
  pdfauthor   = {Roslin Leon Matias},
  pdftitle    = {Roslin Leon Matias -- Resume},
  pdfsubject  = {Lead Software Engineer},
  pdfkeywords = {Lead Software Engineer, Java, Spring Boot, AWS, React,
                 TypeScript, Microservices, Kubernetes, Cloud-Native,
                 Spring WebFlux, Reactive Programming, Kafka, Docker},
  pdfcreator  = {XeLaTeX + resume.sty},
  pdfproducer = {XeLaTeX},
}

%% ── List control ────────────────────────────────────────────
\RequirePackage{enumitem}

%% ── Section heading formatting ──────────────────────────────
\RequirePackage{titlesec}

%%  SECTION NAME  (9.5pt, bold, uppercase, navy)
%%  ──────────────── (sky-blue rule, 1.2pt)
\titleformat{\section}
  {\normalfont\fontsize{9.5}{11}\selectfont\bfseries\color{cvTitle}}
  {}
  {0em}
  {\MakeUppercase}
  [\vspace{1pt}%
   {\color{cvRule}\rule{\linewidth}{1.2pt}}%
   \vspace{-5pt}]

\titlespacing*{\section}
  {0pt}   %% left indent
  {7pt}   %% space before section
  {5pt}   %% space after rule

%% ── Paragraph spacing ───────────────────────────────────────
\RequirePackage{parskip}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}

%% ── Micro-typography ────────────────────────────────────────
\RequirePackage{microtype}

%% ── Additional utility packages ─────────────────────────────
\RequirePackage{etoolbox}   %% LaTeX programming utilities

%% Apply global body text color
\AtBeginDocument{\color{cvText}}

%% ============================================================
%%  CUSTOM COMMANDS
%% ============================================================

%% ── Header commands ─────────────────────────────────────────

%% \cvName{Full Name}
%%   Renders the candidate name — large, bold, dark navy.
\newcommand{\cvName}[1]{%
  {\fontsize{22}{26}\selectfont\bfseries\color{cvName}#1}\par%
}

%% \cvHeadTitle{Professional Title}
%%   Renders the professional title below the name.
\newcommand{\cvHeadTitle}[1]{%
  \vspace{3pt}%
  {\fontsize{11}{13}\selectfont\color{cvTitle}#1}\par%
}

%% \cvContact{text}
%%   Renders a single-line contact block (plain text, ATS-safe).
%%   Use \cvSep between items.
\newcommand{\cvContact}[1]{%
  \vspace{5pt}%
  {\fontsize{9}{11}\selectfont\color{cvMuted}#1}\par%
  \vspace{2pt}%
  {\color{cvRule}\rule{\linewidth}{0.6pt}}%
  \vspace{4pt}%
}

%% \cvSep  —  separator between contact items
\newcommand{\cvSep}{\enspace\textbar\enspace}

%% ── Experience entry commands ─────────────────────────────────

%% \cvEntry{Role}{Organization — Location}{Date range}
%%   Standard experience block header.
%%   Role is bold; Organization is colored italic; Date is muted right-aligned.
\newcommand{\cvEntry}[3]{%
  \vspace{2pt}%
  \noindent%
  {\textbf{#1}\hfill{\footnotesize\color{cvMuted}#3}}\\[-3pt]%
  {\small\color{cvTitle}\textit{#2}}%
  \vspace{1pt}%
}

%% \cvEntryClient{Role}{Organization}{Client}{Project}{Date range}
%%   Experience block with named client and project.
\newcommand{\cvEntryClient}[5]{%
  \vspace{2pt}%
  \noindent%
  {\textbf{#1}\hfill{\footnotesize\color{cvMuted}#5}}\\[-3pt]%
  {\small\color{cvTitle}\textit{#2}}\\[-3pt]%
  {\footnotesize\color{cvMuted}\textit{Client:}~\textbf{#3}\enspace\textbar\enspace\textit{Project:}~\textbf{#4}}%
  \vspace{1pt}%
}

%% cvItems  —  compact bullet list for experience entries
\newenvironment{cvItems}{%
  \begin{itemize}[%
    leftmargin  = 1.4em,%
    itemsep     = 0.5pt,%
    topsep      = 3pt,%
    parsep      = 0pt,%
    partopsep   = 0pt,%
    label       = \raisebox{0.1ex}{\tiny$\blacksquare$}%
  ]%
  \small%
}{%
  \end{itemize}%
  \vspace{1pt}%
}

%% \cvItem{text}  —  single bullet inside cvItems
\newcommand{\cvItem}[1]{\item #1}

%% ── Skills command ───────────────────────────────────────────

%% \skillLine{Category}{Technologies}
%%   Single-column, ATS-safe: "Category: Tech A, Tech B, Tech C"
\newcommand{\skillLine}[2]{%
  {\small\textbf{#1:}\enspace#2}\par\vspace{1.5pt}%
}

%% ── Education/Certification command ─────────────────────────

%% \cvEduEntry{Degree/Cert}{Institution}{Date}
\newcommand{\cvEduEntry}[3]{%
  \vspace{2pt}%
  \noindent%
  {\textbf{#1}\hfill{\footnotesize\color{cvMuted}#3}}\\[-3pt]%
  {\small\color{cvTitle}\textit{#2}}%
  \vspace{1pt}%
}

%% ── Additional experience (condensed) ────────────────────────

%% \cvMiniEntry{Role}{Company — Client}{Date range}
\newcommand{\cvMiniEntry}[3]{%
  \vspace{1pt}%
  {\small\textbf{#1}\enspace\textbar\enspace\textit{#2}\hfill{\footnotesize\color{cvMuted}#3}}\par%
}
