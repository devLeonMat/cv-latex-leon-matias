%% ============================================================
%%  resume.sty  —  Professional CV Style
%%  Candidate : Roslin Leon Matias
%%  Engine    : XeLaTeX  (required for fontspec)
%%  Compatible: Overleaf · VS Code + LaTeX Workshop · MacTeX
%%
%%  Font: TeX Gyre Heros (Helvetica Neue clone)
%%  Bundled in all TeX Live installs — no extra package needed.
%% ============================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{resume}[2026/07/14 v2.0 Roslin Leon Matias Resume Style]

%% ── Engine guard ────────────────────────────────────────────
\RequirePackage{ifxetex}
\ifxetex\else
  \PackageError{resume}%
    {This style requires XeLaTeX.\MessageBreak Compile with: xelatex resume.tex}%
    {Use xelatex instead of pdflatex or lualatex.}%
\fi

%% ── Page geometry  (A4, tight but comfortable margins) ──────
\RequirePackage[
  a4paper,
  top    = 1.6cm,
  bottom = 1.5cm,
  left   = 1.75cm,
  right  = 1.75cm
]{geometry}

%% ── Font packages ───────────────────────────────────────────
%%  fontspec loads OpenType/TrueType fonts via XeLaTeX.
%%
%%  TeX Gyre Heros is a high-quality Helvetica Neue clone included
%%  in every TeX Live distribution (Overleaf, MacTeX, CI — all work
%%  out-of-the-box with zero extra installation).
%%
%%  To switch to Source Sans 3: install sourcesanspro via tlmgr and
%%  replace TeX Gyre Heros → Source Sans 3 below.
\RequirePackage{fontspec}

\setmainfont{TeX Gyre Heros}[
  BoldFont       = {TeX Gyre Heros Bold},
  ItalicFont     = {TeX Gyre Heros Italic},
  BoldItalicFont = {TeX Gyre Heros Bold Italic},
  Scale          = 1.0,
]
\setsansfont{TeX Gyre Heros}

%% ── Color palette ───────────────────────────────────────────
%%  Plain black & white — matches candidate's prior ATS-safe PDF.
\RequirePackage{xcolor}

\definecolor{cvName}     {HTML}{000000}   %% Black — candidate name
\definecolor{cvTitle}    {HTML}{000000}   %% Black — section headings, role titles
\definecolor{cvAccent}   {HTML}{1B4F5C}   %% Dark teal — company/client line, links
\definecolor{cvText}     {HTML}{000000}   %% Black — body text
\definecolor{cvMuted}    {HTML}{333333}   %% Dark gray — secondary labels (Stack: line)
\definecolor{cvRule}     {HTML}{000000}   %% Black — horizontal rules under sections

%% ── Hyperref (links + PDF metadata) ─────────────────────────
\RequirePackage{hyperref}
\hypersetup{
  colorlinks  = true,
  urlcolor    = cvAccent,
  pdfauthor   = {Roslin Leon Matias},
  pdftitle    = {Roslin Leon Matias -- Resume},
  pdfsubject  = {Lead Software Engineer},
  pdfkeywords = {Lead Software Engineer, Java, Spring Boot, AWS, React,
                 TypeScript, Microservices, Kubernetes, Cloud-Native,
                 Spring WebFlux, Reactive Programming, Kafka, Docker},
  pdfcreator  = {XeLaTeX + resume.sty},
  pdfproducer = {XeLaTeX},
}

%% ── List control ────────────────────────────────────────────
\RequirePackage{enumitem}

%% ── Section heading formatting ──────────────────────────────
\RequirePackage{titlesec}

%%  SECTION NAME  (11pt, bold, uppercase, black)
%%  ──────────────── (black rule, 0.8pt)
\titleformat{\section}
  {\normalfont\fontsize{11}{13}\selectfont\bfseries\color{cvTitle}}
  {}
  {0em}
  {\MakeUppercase}
  [\vspace{1pt}%
   {\color{cvRule}\rule{\linewidth}{0.8pt}}%
   \vspace{-5pt}]

\titlespacing*{\section}
  {0pt}   %% left indent
  {7pt}   %% space before section
  {5pt}   %% space after rule

%% ── Paragraph spacing ───────────────────────────────────────
\RequirePackage{parskip}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}

%% ── Micro-typography ────────────────────────────────────────
\RequirePackage{microtype}

%% ── Additional utility packages ─────────────────────────────
\RequirePackage{etoolbox}   %% LaTeX programming utilities

%% Apply global body text color
\AtBeginDocument{\color{cvText}}

%% ============================================================
%%  CUSTOM COMMANDS
%% ============================================================

%% ── Header commands ─────────────────────────────────────────

%% \cvName{Full Name}
%%   Renders the candidate name — large, bold, black.
\newcommand{\cvName}[1]{%
  {\fontsize{20}{24}\selectfont\bfseries\color{cvName}#1}\par%
}

%% \cvHeadTitle{Professional Title}
%%   Renders the professional title below the name — bold, black.
\newcommand{\cvHeadTitle}[1]{%
  \vspace{2pt}%
  {\fontsize{10.5}{13}\selectfont\bfseries\color{cvTitle}#1}\par%
}

%% \cvContact{text}
%%   Renders a single-line contact block (plain text, ATS-safe).
%%   Use \cvSep between items. No rule — matches source PDF.
\newcommand{\cvContact}[1]{%
  \vspace{4pt}%
  {\fontsize{9.5}{11}\selectfont\color{cvText}#1}\par%
  \vspace{6pt}%
}

%% \cvSep  —  separator between contact items
\newcommand{\cvSep}{\enspace\textbar\enspace}

%% ── Experience entry commands ─────────────────────────────────

%% \cvEntry{Role}{Organization — Location}{Date range}
%%   Standard experience block header.
%%   Role and date are bold black; Organization is dark-teal accent.
\newcommand{\cvEntry}[3]{%
  \vspace{3pt}%
  \noindent%
  {\bfseries#1\hfill\bfseries#3}\\[-2pt]%
  {\small\color{cvAccent}#2}%
  \vspace{1pt}%
}

%% \cvEntryClient{Role}{Organization}{Client}{Project}{Date range}
%%   Experience block with named client and project — single accent line,
%%   matching "Organization | Client | Project: X" from source PDF.
\newcommand{\cvEntryClient}[5]{%
  \vspace{3pt}%
  \noindent%
  {\bfseries#1\hfill\bfseries#5}\\[-2pt]%
  {\small\color{cvAccent}#2\enspace\textbar\enspace#3\enspace\textbar\enspace\textbf{Project:}~#4}%
  \vspace{1pt}%
}

%% cvItems  —  compact bullet list for experience entries
\newenvironment{cvItems}{%
  \begin{itemize}[%
    leftmargin  = 1.4em,%
    itemsep     = 0.5pt,%
    topsep      = 3pt,%
    parsep      = 0pt,%
    partopsep   = 0pt,%
    label       = \textbullet%
  ]%
  \small%
}{%
  \end{itemize}%
  \vspace{1pt}%
}

%% \cvItem{text}  —  single bullet inside cvItems
\newcommand{\cvItem}[1]{\item #1}

%% ── Skills command ───────────────────────────────────────────

%% \skillLine{Category}{Technologies}
%%   Single-column, ATS-safe: "Category: Tech A, Tech B, Tech C"
\newcommand{\skillLine}[2]{%
  {\small\textbf{#1:}\enspace#2}\par\vspace{1.5pt}%
}

%% ── Education/Certification command ─────────────────────────

%% \cvEduEntry{Degree/Cert}{Institution}{Date}
\newcommand{\cvEduEntry}[3]{%
  \vspace{2pt}%
  \noindent%
  {\textbf{#1}\hfill\bfseries#3}\\[-3pt]%
  {\small#2}%
  \vspace{1pt}%
}

%% ── Additional experience (condensed) ────────────────────────

%% \cvMiniEntry{Role}{Company — Client}{Date range}
\newcommand{\cvMiniEntry}[3]{%
  \vspace{1pt}%
  {\small\textbf{#1}\enspace\textbar\enspace\color{cvAccent}#2\color{cvText}\hfill\textbf{#3}}\par%
}
